    <string name="app_tab_stream_harmony_title">HarmonyOS 4.2 setup guide</string>
    <string name="app_tab_stream_harmony_summary">Before first use, complete these settings to reduce background cleanup, screen capture interruptions, and unexpected stream stops.</string>
    <string name="app_tab_stream_harmony_checklist_title">Recommended before you start</string>
    <string name="app_tab_stream_harmony_step_1_title">Allow notifications</string>
    <string name="app_tab_stream_harmony_step_1_summary">The app needs notifications to keep the foreground streaming service alive.</string>
    <string name="app_tab_stream_harmony_step_2_title">Allow screen capture</string>
    <string name="app_tab_stream_harmony_step_2_summary">When you start streaming, accept the system screen capture request and avoid canceling it.</string>
    <string name="app_tab_stream_harmony_step_3_title">Turn off automatic battery restrictions</string>
    <string name="app_tab_stream_harmony_step_3_summary">Set battery management to unrestricted or allow the app to stay active in the background.</string>
    <string name="app_tab_stream_harmony_step_4_title">Lock the app in recent tasks</string>
    <string name="app_tab_stream_harmony_step_4_summary">If HarmonyOS provides task locking or protected apps, enable it to reduce background cleanup.</string>
    <string name="app_tab_stream_harmony_recovery_title">Background running tip</string>
    <string name="app_tab_stream_harmony_recovery_summary">If streaming stops after locking the screen, switching apps, or waiting a few minutes, check notifications, battery management, and background activity settings first.</string>
